# ------------------------------------------------------------
# Physics.explained — environment template
# Copy to `.env.local` and fill in real values. Never commit real secrets here.
# ------------------------------------------------------------

# --- Supabase (dedicated `physics` project) ---
#
# Find these in the Supabase dashboard:
#   Settings → API → Project URL / Project API Keys
#
# NEXT_PUBLIC_* vars are exposed to the browser bundle — only put PUBLIC keys here.
# The service role key is server-only and must never be prefixed with NEXT_PUBLIC.

NEXT_PUBLIC_SUPABASE_URL=https://cpcgkkedcfbnlfpzutrc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNwY2dra2VkY2ZibmxmcHp1dHJjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU5MzUyNjYsImV4cCI6MjA5MTUxMTI2Nn0.CK7UJrY3bTtP5L-khOYsbLE7NxxheCGmzQfemTXBUgI

# Server-only. Used by server actions that need to bypass RLS
# (reading messages, admin tasks). Do NOT expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNwY2dra2VkY2ZibmxmcHp1dHJjIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NTkzNTI2NiwiZXhwIjoyMDkxNTExMjY2fQ.pnHL977wWT8Nupa63IV3_s0GuDmzuKe1k0X5Jjmghvw


# --- Optional: contact-form abuse protection ---
# Pepper for hashing client IPs before storing in contact_messages.ip_hash.
# Any long random string; rotate if leaked.
CONTACT_IP_PEPPER=change-me-to-a-long-random-string


# --- Site URL (REQUIRED in production) ---
# Used for canonical links, og:image, and receipt-email CTA links.
# lib/billing/email.ts throws if this is missing — set it in every env.
# Production value: https://physics.it.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# --- /ask AI tutor ---
# Kill switch — set to false to disable the feature entirely (banner + 503).
ASK_ENABLED=true

# At least one of these is required. The model dropdown in /ask lets the
# user pick per-message; missing keys just mean those models will 500.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# Optional: Brave Search for the webSearch tool. If absent, the tool
# degrades gracefully and returns no results.
BRAVE_SEARCH_API_KEY=...

# Rate-limit overrides (all have sensible defaults baked into code):
# ASK_RATE_LIMIT_FREE_MSGS=20
# ASK_RATE_LIMIT_FREE_TOKENS_IN=60000
# ASK_RATE_LIMIT_FREE_TOKENS_OUT=20000


# --- Billing (Revolut Merchant) ---
# Revolut Business → Merchant → APIs. Keep secrets server-only.
#
# TODO: The Revolut API version pin in lib/billing/revolut.ts is 2024-09-01.
# Revolut releases breaking API changes; review their changelog at
# https://developer.revolut.com/docs/merchant/api-changelog at least once
# a year and bump the `Revolut-Api-Version` header if safe.
REVOLUT_ENV=sandbox                                       # sandbox | production
REVOLUT_API_KEY=sk_...                                    # Server-only secret (never NEXT_PUBLIC_)
REVOLUT_WEBHOOK_SECRET=wsk_...                            # Revolut webhook secret (wsk_ prefix). Set in Revolut dashboard when registering webhook.
NEXT_PUBLIC_REVOLUT_ENV=sandbox                           # Mirrors REVOLUT_ENV for the browser SDK (public)

# Note: Revolut's browser SDK uses the per-order `public_id` returned from
# createOrder() — there is no global "public key" like Stripe's `pk_...`.
# NEXT_PUBLIC_REVOLUT_PUBLIC_KEY is therefore NOT required.


# --- Transactional email (via n8n on Polish VPS) ---
# Receipts are sent by POSTing to an n8n webhook that fans out to Hostinger
# SMTP. This keeps SMTP creds on the VPS (inside n8n) instead of in the
# Next.js deploy. The workflow is `Physics.it.com — Transactional Email` on
# https://n8n.dopplervpn.org and requires the X-Webhook-Secret header.
N8N_EMAIL_WEBHOOK_URL=https://n8n.dopplervpn.org/webhook/physics-email-send
N8N_WEBHOOK_SECRET=dpvpn-webhook-a0f9e8a99aaf4f12ac69a92f19ed9151
EMAIL_FROM="Physics.it.com <support@simnetiq.store>"   # Swap to support@physics.it.com when that mailbox exists

# --- (Legacy) Transactional email (Hostinger SMTP) — NO LONGER USED BY APP ---
# Kept here purely for reference; SMTP auth now lives as a credential inside
# the n8n instance on the Polish VPS. The app no longer reads SMTP_*.
# Used for payment receipts. The shared Doppler Hostinger mailbox
# (support@simnetiq.store) is fine short-term; switch SMTP_FROM to a
# physics.explained address once DNS + mailbox are set up.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=support@simnetiq.store
SMTP_PASS=...                                             # From Hostinger email panel
# Long-term form (switch once physics.explained DNS is ready):
SMTP_FROM="Physics.explained <support@physics.explained>"
# Short-term form (works today on the shared simnetiq.store mailbox):
# SMTP_FROM="Physics.explained <support@simnetiq.store>"

# Optional postal address appended to receipt emails. Helps Gmail delivery
# reputation. If unset, the line is silently omitted.
# BILLING_COMPANY_ADDRESS="Dortmund, Germany"
