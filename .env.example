# ------------------------------------------------------------
# Physics.explained — environment template
# Copy to `.env.local` and fill in real values. Never commit real secrets here.
# ------------------------------------------------------------

# --- Supabase (dedicated `physics` project) ---
#
# Find these in the Supabase dashboard:
#   Settings → API → Project URL / Project API Keys
#
# NEXT_PUBLIC_* vars are exposed to the browser bundle — only put PUBLIC keys here.
# The service role key is server-only and must never be prefixed with NEXT_PUBLIC.

NEXT_PUBLIC_SUPABASE_URL=https://cpcgkkedcfbnlfpzutrc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNwY2dra2VkY2ZibmxmcHp1dHJjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU5MzUyNjYsImV4cCI6MjA5MTUxMTI2Nn0.CK7UJrY3bTtP5L-khOYsbLE7NxxheCGmzQfemTXBUgI

# Server-only. Used by server actions that need to bypass RLS
# (reading messages, admin tasks). Do NOT expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNwY2dra2VkY2ZibmxmcHp1dHJjIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NTkzNTI2NiwiZXhwIjoyMDkxNTExMjY2fQ.pnHL977wWT8Nupa63IV3_s0GuDmzuKe1k0X5Jjmghvw


# --- Optional: contact-form abuse protection ---
# Pepper for hashing client IPs before storing in contact_messages.ip_hash.
# Any long random string; rotate if leaked.
CONTACT_IP_PEPPER=change-me-to-a-long-random-string


# --- Optional: site URL for canonical links / absolute og:image ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# --- /ask AI tutor ---
# Kill switch — set to false to disable the feature entirely (banner + 503).
ASK_ENABLED=true

# At least one of these is required. The model dropdown in /ask lets the
# user pick per-message; missing keys just mean those models will 500.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# Optional: Brave Search for the webSearch tool. If absent, the tool
# degrades gracefully and returns no results.
BRAVE_SEARCH_API_KEY=...

# Rate-limit overrides (all have sensible defaults baked into code):
# ASK_RATE_LIMIT_FREE_MSGS=20
# ASK_RATE_LIMIT_FREE_TOKENS_IN=60000
# ASK_RATE_LIMIT_FREE_TOKENS_OUT=20000


# --- Billing (Revolut Merchant) ---
# Revolut Business → Merchant → APIs. Keep secrets server-only.
REVOLUT_ENV=sandbox                                       # sandbox | production
REVOLUT_API_KEY=sk_...                                    # Server-only secret (never NEXT_PUBLIC_)
REVOLUT_WEBHOOK_SECRET=whsec_...                          # Set in Revolut dashboard when registering webhook
NEXT_PUBLIC_REVOLUT_PUBLIC_KEY=pk_...                     # Public, used by RevolutCheckout.js
NEXT_PUBLIC_REVOLUT_ENV=sandbox                           # Mirrors REVOLUT_ENV for the browser SDK (public)
