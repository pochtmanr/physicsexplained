# ------------------------------------------------------------
# Physics.explained — environment template
# Copy to `.env.local` and fill in real values. Never commit real secrets here.
# ------------------------------------------------------------

# --- Supabase (dedicated `physics` project) ---
#
# Find these in the Supabase dashboard:
#   Settings → API → Project URL / Project API Keys
#
# NEXT_PUBLIC_* vars are exposed to the browser bundle — only put PUBLIC keys here.
# The service role key is server-only and must never be prefixed with NEXT_PUBLIC.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...public-anon-key...

# Server-only. Used by server actions that need to bypass RLS
# (reading messages, admin tasks). Do NOT expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key...


# --- Optional: contact-form abuse protection ---
# Pepper for hashing client IPs before storing in contact_messages.ip_hash.
# Generate with: openssl rand -hex 32
CONTACT_IP_PEPPER=change-me-to-a-long-random-string


# --- Optional: site URL for canonical links / absolute og:image ---
# In dev: http://localhost:3000
# In prod: https://physics.explained  (or your Vercel URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
